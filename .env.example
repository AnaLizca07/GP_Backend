# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
# IMPORTANTE: Para crear empleados necesitas la service_role_key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend
FRONTEND_URL=http://localhost:3000

# Environment
ENVIRONMENT=development

# === CONFIGURACIÓN SMTP PARA EMAILS PERSONALIZADOS ===

# Servidor SMTP (ejemplo: smtp.gmail.com, smtp.outlook.com, mail.tuempresa.com)
SMTP_HOST=smtp.gmail.com

# Puerto SMTP (587 para TLS, 465 para SSL, 25 para sin cifrado)
SMTP_PORT=587

# Usuario SMTP (generalmente tu email)
SMTP_USER=tu-email@gmail.com

# Contraseña SMTP (puede ser contraseña de aplicación para Gmail)
SMTP_PASSWORD=tu-contraseña-o-app-password

# Email remitente (por defecto usa SMTP_USER)
SMTP_FROM_EMAIL=noreply@tuempresa.com

# Nombre del remitente
SMTP_FROM_NAME=Sistema PMIS

# Usar TLS (true/false) - recomendado: true
SMTP_USE_TLS=true